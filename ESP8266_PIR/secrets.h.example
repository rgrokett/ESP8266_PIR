const char WIFI_PASSWORD[] = "YOUR_WIFI_PASSWORD";
const char IFTTT_API_KEY[] = "YOUR_IFTTT_WEBHOOK_KEY";
const char IFTTT_EVENT[] = "pirtrigger";

/*
 * TLS_VALIDATE_CA is recommended. Paste the PEM-encoded root CA certificate
 * that validates maker.ifttt.com into IFTTT_CA_CERT.
 *
 * TLS_VALIDATE_FINGERPRINT is simpler but must be updated whenever IFTTT
 * changes its certificate.
 *
 * TLS_INSECURE disables server authentication and should only be used for
 * temporary diagnostics on a trusted network.
 */
const TlsValidationMode TLS_VALIDATION = TLS_VALIDATE_CA;

const char IFTTT_CA_CERT[] PROGMEM = R"EOF(
)EOF";

const char IFTTT_FINGERPRINT[] =
    "REPLACE WITH 20-BYTE SHA1 CERTIFICATE FINGERPRINT";
